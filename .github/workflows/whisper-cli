name: Build Whisper CLI for Android (Fixed)

on:
  workflow_dispatch:

jobs:
  build-android:
    runs-on: ubuntu-22.04
    
    steps:
      - name: Checkout whisper.cpp
        uses: actions/checkout@v4
      
      - name: Setup Android NDK
        uses: nttld/setup-ndk@v1
        with:
          ndk-version: r26b
          add-to-path: true
      
      - name: Install dependencies
        run: |
          sudo apt-get update
          sudo apt-get install -y cmake ninja-build
      
      - name: Build for arm64-v8a (Static)
        run: |
          mkdir -p build-android
          cd build-android
          
          # Configure with static linking
          cmake .. \
            -G Ninja \
            -DCMAKE_TOOLCHAIN_FILE=$ANDROID_NDK_HOME/build/cmake/android.toolchain.cmake \
            -DANDROID_ABI=arm64-v8a \
            -DANDROID_PLATFORM=android-26 \
            -DCMAKE_BUILD_TYPE=Release \
            -DWHISPER_BUILD_EXAMPLES=ON \
            -DBUILD_SHARED_LIBS=OFF \
            -DCMAKE_C_FLAGS="-O3 -static-libgcc" \
            -DCMAKE_CXX_FLAGS="-O3 -static-libstdc++" \
            -DCMAKE_EXE_LINKER_FLAGS="-static-libgcc -static-libstdc++"
          
          # Build
          ninja main
          
          # Verify
          echo "=== Build Info ==="
          ls -lh bin/main
          file bin/main
          ldd bin/main || echo "Static binary (good!)"
          
          # Rename
          cp bin/main whisper-cli-arm64
      
      - name: Upload binary
        uses: actions/upload-artifact@v4
        with:
          name: whisper-cli-android-arm64
          path: build-android/whisper-cli-arm64
          retention-days: 7
      
      - name: Create release info
        run: |
          cd build-android
          echo "Binary size: $(du -h whisper-cli-arm64 | cut -f1)" > build-info.txt
          echo "Build date: $(date)" >> build-info.txt
          file whisper-cli-arm64 >> build-info.txt
      
      - name: Upload build info
        uses: actions/upload-artifact@v4
        with:
          name: build-info
          path: build-android/build-info.txt
